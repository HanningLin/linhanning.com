---
import type { Project } from "../data/projects";

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<div class="group rounded-xl border border-border p-5 transition-colors hover:bg-card-hover">
  <h3 class="text-lg font-semibold text-text group-hover:text-accent transition-colors">
    {project.title}
  </h3>
  <p class="mt-1.5 text-sm text-text-secondary">
    {project.description}
  </p>
  <div class="mt-3 flex flex-wrap gap-1.5">
    {project.tags.map((tag) => (
      <span class="rounded-md bg-tag-bg px-2 py-0.5 text-xs font-medium text-tag-text">
        {tag}
      </span>
    ))}
  </div>
  <div class="mt-4 flex gap-3">
    {project.url && (
      <a
        href={project.url}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm font-medium text-accent hover:text-accent-hover transition-colors"
      >
        Live site &rarr;
      </a>
    )}
    {project.github && (
      <a
        href={project.github}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm font-medium text-text-secondary hover:text-text transition-colors"
      >
        GitHub
      </a>
    )}
  </div>
</div>
