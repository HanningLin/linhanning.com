---
import type { Project } from "../data/projects";

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<div class="panel panel-interactive group h-full px-5 py-5 sm:px-6 sm:py-6">
  <p class="micro-label">Project</p>
  <h3 class="mt-3 font-display text-3xl leading-none tracking-[-0.05em] text-text group-hover:text-accent-soft transition-colors">
    {project.title}
  </h3>
  <p class="mt-3 text-sm leading-7 text-text-secondary">
    {project.description}
  </p>
  <div class="mt-4 flex flex-wrap gap-2">
    {project.tags.map((tag) => (
      <span class="chip">
        {tag}
      </span>
    ))}
  </div>
  <div class="mt-6 flex flex-wrap gap-4">
    {project.url && (
      <a
        href={project.url}
        target="_blank"
        rel="noopener noreferrer"
        class="micro-label text-accent hover:text-accent-hover"
      >
        Live site &rarr;
      </a>
    )}
    {project.github && (
      <a
        href={project.github}
        target="_blank"
        rel="noopener noreferrer"
        class="micro-label hover:text-text"
      >
        GitHub
      </a>
    )}
  </div>
</div>
