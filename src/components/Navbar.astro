---
import ThemeToggle from "./ThemeToggle.astro";

const pathname = Astro.url.pathname;

const links = [
  { href: "/", label: "Home" },
  { href: "/blog", label: "Blog" },
  { href: "/projects", label: "Projects" },
  { href: "/about", label: "About" },
];

function isActive(href: string) {
  if (href === "/") return pathname === "/";
  return pathname.startsWith(href);
}
---

<nav class="sticky top-0 z-50 px-4 pt-4 sm:px-6">
  <div class="mx-auto max-w-6xl">
    <div class="panel flex items-center justify-between px-4 py-3 sm:px-5">
      <a href="/" class="flex items-center gap-3 text-text transition-colors hover:text-accent">
        <span class="flex h-11 w-11 items-center justify-center rounded-2xl border border-border bg-tag-bg font-mono text-[0.72rem] tracking-[0.36em] text-text">
          LL
        </span>
        <span class="hidden sm:block">
          <span class="block text-sm font-semibold uppercase tracking-[0.18em]">Liam Lin</span>
          <span class="block text-xs text-text-secondary">Software notes, systems, experiments</span>
        </span>
      </a>

      <!-- Desktop nav -->
      <div class="hidden items-center gap-1.5 sm:flex">
        {
          links.map((link) => (
            <a
              href={link.href}
              class:list={[
                "nav-link",
                isActive(link.href) ? "nav-link-active" : "",
              ]}
            >
              {link.label}
            </a>
          ))
        }
        <ThemeToggle />
      </div>

      <!-- Mobile menu button -->
      <div class="flex items-center gap-2 sm:hidden">
        <ThemeToggle />
        <button
          id="mobile-menu-btn"
          aria-label="Toggle menu"
          class="cursor-pointer rounded-full border border-border bg-bg-secondary p-2.5 text-text-secondary hover:border-border-strong hover:text-text transition-colors"
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path id="menu-open-icon" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            <path id="menu-close-icon" class="hidden" stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="mx-auto mt-3 hidden max-w-6xl px-4 sm:hidden sm:px-6">
    <div class="panel space-y-1 p-3">
      {
        links.map((link) => (
          <a
            href={link.href}
            class:list={[
              "block rounded-2xl px-3 py-2.5 text-sm font-medium transition-colors",
              isActive(link.href)
                ? "bg-tag-bg text-text"
                : "text-text-secondary hover:bg-bg-secondary hover:text-text",
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </div>
  </div>
</nav>

<script is:inline>
  function setupMobileMenu() {
    const btn = document.getElementById("mobile-menu-btn");
    const menu = document.getElementById("mobile-menu");
    const openIcon = document.getElementById("menu-open-icon");
    const closeIcon = document.getElementById("menu-close-icon");

    if (btn && menu && openIcon && closeIcon) {
      btn.onclick = () => {
        const isOpen = !menu.classList.contains("hidden");
        menu.classList.toggle("hidden");
        openIcon.classList.toggle("hidden");
        closeIcon.classList.toggle("hidden");
      };
    }
  }

  setupMobileMenu();
  document.addEventListener("astro:after-swap", setupMobileMenu);
</script>
