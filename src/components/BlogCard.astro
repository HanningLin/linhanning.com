---
import FormattedDate from "./FormattedDate.astro";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  slug: string;
  index?: number;
}

const { title, description, pubDate, tags, slug, index } = Astro.props;
---

<article class="panel panel-interactive group">
  <a href={`/blog/${slug}`} class="block px-5 py-5 sm:px-6 sm:py-6">
    <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
      {index !== undefined && (
        <span class="micro-label text-accent">{String(index + 1).padStart(2, "0")}</span>
      )}
      <div class="micro-label">
        <FormattedDate date={pubDate} />
      </div>
    </div>

    <div class="mt-4">
      <h3 class="font-display text-2xl leading-none tracking-[-0.05em] text-text sm:text-[2.2rem] group-hover:text-accent-soft transition-colors">
        {title}
      </h3>
      <p class="mt-3 max-w-2xl text-sm leading-7 text-text-secondary sm:text-base">
        {description}
      </p>
      {
        tags.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-2">
            {tags.map((tag) => (
              <span class="chip">{tag}</span>
            ))}
          </div>
        )
      }
    </div>
  </a>
</article>
